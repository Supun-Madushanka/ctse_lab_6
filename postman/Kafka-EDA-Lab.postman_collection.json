      ]
    },

    {
      "name": "3) Direct Service Calls (bypass Gateway)",
      "description": "Call the Order Service directly on port 8081, bypassing the Gateway. Useful for debugging routing or gateway issues.",
      "item": [
        {
          "name": "POST Order direct – Mouse (ORD-2001)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Order accepted (200)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD-2001\",\n  \"item\": \"Wireless Mouse\",\n  \"quantity\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{orderServiceUrl}}/orders",
              "host": ["{{orderServiceUrl}}"],
              "path": ["orders"]
            },
            "description": "Calls Order Service directly on port 8081 (no Gateway)."
          }
        },
        {
          "name": "GET Order Service Custom Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orderServiceUrl}}/orders/health",
              "host": ["{{orderServiceUrl}}"],
              "path": ["orders", "health"]
            },
            "description": "Custom /orders/health endpoint defined in OrderController."
          }
        }
      ]
    }

  ]
