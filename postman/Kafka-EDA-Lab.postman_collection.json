        {
          "name": "POST Order – Headphones (ORD-1004)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Order accepted (200)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
