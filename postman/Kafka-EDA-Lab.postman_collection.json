              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD-1002\",\n  \"item\": \"Mechanical Keyboard\",\n  \"quantity\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        },
